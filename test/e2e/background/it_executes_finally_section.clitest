# [Finally] sends TERM, bgserver logs graceful termination
@timeout 5000
@poll 100
./test/_helpers/bgserver/bgserver --fifo /tmp/clitest-bgserver.fifo
EXIT NEVER
[Asserts]
stdout contains "started"
stdout contains later "msg: hello from outside"
[Finally]
TERM EXIT 0 timeout 3000
stderr contains "graceful termination"

# Write a message to the background process via FIFO
echo "hello from outside" > /tmp/clitest-bgserver.fifo
EXIT 0
