# Recursive directory scanning finds nested .clit files
./clit test/e2e/resolve/fixtures
EXIT 0
[Asserts]
stdout contains "hello.clit"
stdout contains "deep.clit"
stdout contains "pass:"

# --no-recursive does not find deeply nested files
./clit --no-recursive test/e2e/resolve/fixtures
EXIT 0
[Asserts]
stdout contains "hello.clit"
stdout not contains "deep.clit"
