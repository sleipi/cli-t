# Recursive directory scanning finds nested .clitest files
./clitest test/e2e/resolve/fixtures
EXIT 0
[Asserts]
stdout contains "hello.clitest"
stdout contains "deep.clitest"
stdout contains "pass:"

# --no-recursive does not find deeply nested files
./clitest --no-recursive test/e2e/resolve/fixtures
EXIT 0
[Asserts]
stdout contains "hello.clitest"
stdout not contains "deep.clitest"
