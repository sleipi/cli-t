# Parallel flag sets worker count
./clit --parallel 2 examples/01_basic.clit
EXIT 0
[Asserts]
stdout contains "parallel: 2"

# No-parallel flag disables parallelism
./clit --no-parallel examples/01_basic.clit
EXIT 0
[Asserts]
stdout contains "no-parallel"

# --parallel and --no-parallel are mutually exclusive
./clit --parallel 4 --no-parallel examples/01_basic.clit
EXIT 2
[Asserts]
stderr contains "if any flags in the group [parallel no-parallel] are set none of the others can be"
