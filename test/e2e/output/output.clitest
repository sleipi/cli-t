# Header shows version
./clitest examples/01_basic.clitest
EXIT 0
[Asserts]
stdout matches /clitest v\S+/
stdout contains "path:"
stdout contains "1 file loaded"
stdout contains "parallel:"
stdout contains "took:"

# Header shows no-parallel when set
./clitest --no-parallel examples/01_basic.clitest
EXIT 0
[Asserts]
stdout contains "no-parallel"
stdout not contains "parallel:"

# Header shows no-recursive in path line
./clitest --no-recursive test/e2e/resolve/fixtures
EXIT 0
[Asserts]
stdout contains "no-recursive"

# Verbose shown only when active
./clitest -v examples/01_basic.clitest
EXIT 0
[Asserts]
stdout contains "verbose:"

# Verbose not shown by default
./clitest examples/01_basic.clitest
EXIT 0
[Asserts]
stdout not contains "verbose:"

# Multiple paths show separately
./clitest examples/01_basic.clitest examples/02_errors.clitest
EXIT 0
[Asserts]
stdout contains "examples/01_basic.clitest (1 file loaded)"
stdout contains "examples/02_errors.clitest (1 file loaded)"

# Glob pattern preserved in path output
./clitest "examples/0*.clitest"
EXIT 0
[Asserts]
stdout contains "examples/0*.clitest"
stdout contains "file(s) loaded"
