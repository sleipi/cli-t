# Default output shows compact OK line with counter and timing
./clitest examples/01_basic.clitest
EXIT 0
[Asserts]
stdout contains "OK"
stdout contains "[==========]"
stdout contains "01_basic.clitest"
stdout contains "took"
stdout not contains "✓"
stdout not contains "✗"

# Verbose output shows per-entry checkmarks
./clitest -v examples/01_basic.clitest
EXIT 0
[Asserts]
stdout contains "✓"
stdout contains "▶ 01_basic.clitest"
stdout not contains "[==========]"

# Failing file shows ERR in compact mode
./clitest test/_fixtures/failing.clitest
EXIT 1
[Asserts]
stdout contains "ERR"
stdout contains "[==========]"
stdout contains "failing.clitest"
stdout contains "took"

# Multiple files show one line each in compact mode
./clitest examples/01_basic.clitest examples/02_errors.clitest
EXIT 0
[Asserts]
stdout contains "OK"
stdout contains "01_basic.clitest"
stdout contains "02_errors.clitest"
stdout contains "took"

# test loading bar #1 (1sec)
sleep 1
EXIT 0

# test loading bar #2 (1sec)
sleep 1
EXIT 0

# test loading bar #3 (1sec)
sleep 1
EXIT 0

# test loading bar #4 (1sec)
sleep 1
EXIT 0